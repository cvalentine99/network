    {
      "label": "5min bucket, 15000000 bytes → 50000 bytes/sec",
      "total": 15000000,
      "durationMs": 300000,
      "expectedRate": 50000
    },
    {
      "label": "null total → null rate",
      "total": null,
      "durationMs": 30000,
      "expectedRate": null
    },
    {
      "label": "zero duration → null rate (not Infinity)",
      "total": 1048576,
      "durationMs": 0,
      "expectedRate": null
    },
    {
      "label": "negative duration → null rate",
      "total": 1048576,
      "durationMs": -1000,
      "expectedRate": null
    },
    {
      "label": "zero total, valid duration → 0 rate",
      "total": 0,
      "durationMs": 30000,
