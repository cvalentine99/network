# ============================================================
# Network Performance Dashboard — Environment Variables
# ============================================================
# Copy this file to .env in the project root and fill in values.
#   cp deploy/env.template .env
# ============================================================

# ---------- Server ----------
# Port the Express server listens on (default: 3000)
PORT=3000

# Node environment: "production" for deployed instances
NODE_ENV=production

# ---------- Database (MySQL 8+ / TiDB) ----------
# Full connection string. Example:
#   mysql://user:password@host:3306/network_perf?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://user:password@localhost:3306/network_perf

# ---------- Authentication ----------
# Secret used to sign JWT session cookies (min 32 chars, random)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS

# ---------- Lab / Local Deploy ----------
# These are required by the server startup but are unused in local/lab mode.
# Leave them as-is for baremetal or Docker deployment.
VITE_APP_ID=local-lab
OAUTH_SERVER_URL=
OWNER_OPEN_ID=local-lab-owner
OWNER_NAME=Lab Admin
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ---------- ExtraHop Appliance ----------
# If set, these override the DB-stored appliance config.
# Leave blank to configure via the Settings page in the UI.
EH_HOST=
EH_API_KEY=

# Set to "false" to skip TLS certificate verification for self-signed certs
# EH_VERIFY_SSL=false

# ETL polling interval in milliseconds (default: 300000 = 5 min)
ETL_INTERVAL_MS=300000

# ---------- Analytics (optional) ----------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ---------- App Branding (optional) ----------
VITE_APP_TITLE=NetPerf NOC
VITE_APP_LOGO=
